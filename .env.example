# My Virtual World configuration

# Outside Docker host port. Change this if 8590 is already in use.
VW_HOST_PORT=8590

# App port inside the container. Most installs should leave this at 8590.
VW_PORT=8590
VW_DATA_DIR=/data
VW_OPENCLAW_PATH=/openclaw
VW_OPENCLAW_HOST_PATH=~/.openclaw
VW_GATEWAY_URL=ws://host.docker.internal:18789

# Optional OpenClaw gateway token. Leave empty unless your gateway requires one.
VW_GATEWAY_TOKEN=

# Optional realtime sidecar for Live Agent Mode online-game runtime state.
# Docker Compose starts the sidecar by default. Keep this port private
# to your machine, LAN, or VPN unless you put an authenticated proxy in front.
# This is the WebSocket URL browsers can reach for this self-hosted install.
# Same machine: ws://127.0.0.1:8591
# LAN/Tailscale: ws://<your-server-host-or-ip>:8591
# Reverse proxy/TLS: wss://<your-domain>/realtime
VW_REALTIME_ENABLED=true
VW_REALTIME_BROWSER_URL=ws://127.0.0.1:8591
# Backwards-compatible alias. Leave empty unless an older script expects it.
VW_REALTIME_URL=
VW_REALTIME_ROOM=agent_runtime
VW_REALTIME_HOST_PORT=8591
VW_REALTIME_PORT=8591
VW_REALTIME_CHECKPOINT_INTERVAL_MS=5000

# Live Agent persistence budgets (bytes) and world metadata write hygiene.
# Defaults are suitable for normal installs; increase only for unusually large
# histories after confirming available disk space.
VW_WORLD_ACTION_HISTORY_MAX_BYTES=8388608
VW_WORLD_ACTION_HISTORY_RECORD_MAX_BYTES=262144
VW_MOVE_INTENT_HISTORY_MAX_RECORDS=1000
VW_MOVE_INTENT_HISTORY_MAX_BYTES=2097152
VW_MOVE_INTENT_HISTORY_RECORD_MAX_BYTES=8192
VW_MOVE_INTENT_ACTIVE_RECORD_MAX_BYTES=262144
VW_WORLD_ACTION_EVENTS_MAX_EVENTS=1000
VW_WORLD_ACTION_EVENTS_MAX_BYTES=2097152
VW_WORLD_ACTION_EVENT_RECORD_MAX_BYTES=8192
VW_WORLD_META_BACKUP_INTERVAL_SEC=300
VW_WORLD_META_STALE_TMP_MAX_AGE_SEC=3600
VW_LIVE_AGENT_COLLECTION_MAX_BYTES=262144
VW_LIVE_AGENT_LOOP_STATE_MAX_BYTES=8388608
VW_LIVE_AGENT_INTERNAL_NOTES_MAX_BYTES=1048576
VW_LIVE_AGENT_INTERNAL_NOTE_DETAILS_MAX_BYTES=24576
VW_LIVE_AGENT_INTERNAL_NOTE_RECORD_MAX_BYTES=32768
VW_LIVE_AGENT_PLANNER_TRANSCRIPTS_MAX_BYTES=2097152
VW_LIVE_AGENT_PLANNER_TRANSCRIPT_RECORD_MAX_BYTES=49152
VW_LIVE_AGENT_PLANNER_FULL_TURNS_PER_AGENT=8
VW_LIVE_AGENT_PROMPT_CHAR_BUDGET=6000
VW_LIVE_AGENT_MODEL_CIRCUIT_FAILURE_THRESHOLD=2
VW_LIVE_AGENT_MODEL_CIRCUIT_BASE_SEC=180
VW_LIVE_AGENT_MODEL_CIRCUIT_MAX_SEC=1800

# Optional Hermes integration.
VW_HERMES_ENABLED=true
VW_HERMES_HOST_HOME=~/.hermes
VW_HERMES_HOST_BIN=~/.local/bin/hermes
VW_HERMES_HOST_UV=~/.local/share/uv
VW_HERMES_HOME=/home/vw/.hermes
VW_HERMES_BIN=/home/vw/.local/bin/hermes
VW_HERMES_CONTAINER_UV=/home/vw/.local/share/uv
VW_HERMES_TIMEOUT_SEC=600
VW_HERMES_API_URL=http://127.0.0.1:8642
VW_HERMES_API_KEY=
VW_HERMES_PREFER_API=true
VW_HERMES_AUTO_START_PROFILE_APIS=true
VW_HERMES_AUTO_START_DEFAULT_API=true
VW_HERMES_API_PROFILE_PORT_BASE=8643

# Optional Codex integration.
CODEX_HOME=/home/vw/.codex
VW_CODEX_ENABLED=true
VW_CODEX_HOME=/home/vw/.codex
VW_CODEX_BIN=/home/vw/.codex/packages/standalone/current/bin/codex
VW_CODEX_WORKSPACE_ROOT=/data/codex-agents
VW_CODEX_MAIN_WORKSPACE=/data/codex-main
VW_CODEX_TIMEOUT_SEC=900
VW_CODEX_MODEL=
VW_CODEX_SANDBOX=workspace-write
VW_CODEX_APPROVAL_POLICY=never
VW_CODEX_PREFER_APP_SERVER=true
VW_CODEX_INCLUDE_MAIN=true
VW_CODEX_INCLUDE_NATIVE_AGENTS=true
VW_CODEX_REGISTER_NATIVE_AGENTS=true

# Optional Claude Code setup fields. Settings can be saved now; live Claude Code
# agents still need the provider runtime ported into My Virtual World.
CLAUDE_CONFIG_DIR=/home/vw/.claude
VW_CLAUDE_CODE_ENABLED=false
VW_CLAUDE_CODE_HOST_HOME=~/.claude
VW_CLAUDE_CODE_HOME=/home/vw/.claude
VW_CLAUDE_CODE_BIN=claude
VW_CLAUDE_CODE_WORKSPACE_ROOT=/data/claude-code-agents
VW_CLAUDE_CODE_MAIN_WORKSPACE=/data/claude-code-main
VW_CLAUDE_CODE_TIMEOUT_SEC=900
VW_CLAUDE_CODE_MODEL=
VW_CLAUDE_CODE_PERMISSION_MODE=acceptEdits
VW_CLAUDE_CODE_INCLUDE_MAIN=true
VW_CLAUDE_CODE_INCLUDE_NATIVE_AGENTS=true
VW_CLAUDE_CODE_REGISTER_NATIVE_AGENTS=true

# Lemon Squeezy product validation. These public IDs make sure keys belong to My Virtual World.
VW_LICENSE_STORE_ID=321733
VW_LICENSE_PRODUCT_IDS=1140366

# Optional external provider relay.
VW_AGENT_PLATFORM_PROVIDER_URL=

# Optional browser panel. Only use on trusted networks.
BROWSER_VNC_PASSWORD=

# Optional SMS integration. Keep these empty unless configured locally.
VW_TWILIO_ACCOUNT_SID=
VW_TWILIO_AUTH_TOKEN=
VW_TWILIO_FROM_NUMBER=
