# My Virtual World configuration

# Outside Docker host port. Change this if 8590 is already in use.
VW_HOST_PORT=8590

# App port inside the container. Most installs should leave this at 8590.
VW_PORT=8590
VW_DATA_DIR=/data
VW_OPENCLAW_PATH=/openclaw
VW_GATEWAY_URL=ws://host.docker.internal:18789

# Optional OpenClaw gateway token. Leave empty unless your gateway requires one.
VW_GATEWAY_TOKEN=

# Optional Hermes integration.
VW_HERMES_ENABLED=true
VW_HERMES_HOME=/home/vw/.hermes
VW_HERMES_BIN=/home/vw/.local/bin/hermes
VW_HERMES_TIMEOUT_SEC=600

# Lemon Squeezy product validation. These public IDs make sure keys belong to My Virtual World.
VW_LICENSE_STORE_ID=321733
VW_LICENSE_PRODUCT_IDS=1140503

# Optional external provider relay.
VW_AGENT_PLATFORM_PROVIDER_URL=

# Optional browser panel. Only use on trusted networks.
BROWSER_VNC_PASSWORD=

# Optional SMS integration. Keep these empty unless configured locally.
VW_TWILIO_ACCOUNT_SID=
VW_TWILIO_AUTH_TOKEN=
VW_TWILIO_FROM_NUMBER=
