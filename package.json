{
  "name": "my-virtual-world",
  "version": "1.0.31",
  "description": "A self-hosted 3D AI virtual world for agent harnesses like OpenClaw and Hermes.",
  "homepage": "https://myvirtualworld.ai/",
  "repository": {
    "type": "git",
    "url": "https://github.com/eliautobot/my-virtual-world.git"
  },
  "bugs": {
    "url": "https://github.com/eliautobot/my-virtual-world/issues"
  },
  "keywords": [
    "ai-agents",
    "virtual-world",
    "threejs",
    "self-hosted",
    "openclaw"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "python3 src/server/server.py",
    "dev": "VW_PORT=${VW_PORT:-8590} VW_DATA_DIR=${VW_DATA_DIR:-.local-data} python3 src/server/server.py",
    "dev:realtime": "node scripts/dev-with-realtime.mjs",
    "realtime": "node src/realtime/server.mjs",
    "test": "npm run verify:smoke",
    "verify:endurance": "python3 scripts/verify-live-agent-endurance.py",
    "verify:lived-session": "python3 scripts/verify-live-agent-lived-session.py",
    "verify:spatial": "python3 scripts/verify-live-agent-spatial-perception.py",
    "verify:smoke": "node scripts/verify-smoke.mjs",
    "verify:realtime": "node scripts/verify-realtime-smoke.mjs"
  },
  "dependencies": {
    "@colyseus/core": "^0.17.44",
    "@colyseus/schema": "^4.0.26",
    "@colyseus/sdk": "^0.17.43",
    "@colyseus/ws-transport": "^0.17.13",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "express": "^5.2.1",
    "three": "^0.183.2",
    "yuka": "^0.7.8"
  }
}
